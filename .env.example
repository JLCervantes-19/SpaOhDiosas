# ============================================================
# ARCHIVO DE EJEMPLO DE CONFIGURACIÓN
# ============================================================
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales
# NUNCA subas el archivo .env a Git (ya está en .gitignore)

# ============================================================
# CONFIGURACIÓN DE SUPABASE
# ============================================================
# Obtén estas credenciales desde: https://app.supabase.com
# Settings → API

SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# CONFIGURACIÓN DE N8N WEBHOOK (OPCIONAL)
# ============================================================
# Si tienes un webhook de N8N para respuestas inteligentes,
# coloca la URL aquí. Si no lo configuras, el sistema usará
# respuestas locales automáticamente.

N8N_CHAT_WEBHOOK=

# Ejemplo de URL de N8N:
# N8N_CHAT_WEBHOOK=https://tu-instancia-n8n.com/webhook/chat-serenita

# ============================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================

PORT=3000
FRONTEND_URL=http://localhost:3000

# ============================================================
# OTRAS CONFIGURACIONES
# ============================================================

WHATSAPP_NUMBER=573001234567
